# Matrix (Synapse + Element) - Environment Variables
# Copy to app.env and customize
# NOTE: On first run, generate config with:
#   docker run --rm -v ./volumes/config/synapse:/data matrixdotorg/synapse generate

# Timezone
TZ=America/New_York

# Host settings
BASE_HOST_NAME=matrix.example.com

# Database (PostgreSQL)
DB_CREATE_DATABASE_NAME=synapse
DB_USER_NAME=synapse
DB_USER_PASS=changeme_db_password

# Synapse settings
SYNAPSE_REPORT_STATS=no
SYNAPSE_LOG_LEVEL=WARNING
